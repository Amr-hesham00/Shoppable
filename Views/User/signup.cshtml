
@model SignUpVM



<div class="container vh-100 d-flex align-items-center justify-content-center overflow-auto py-4">

    <div class="col-md-6 mx-auto">

        <div class="card shadow-lg border-0 rounded-4">
            <div class="card-body p-5" style="max-height: 90vh; overflow-y: auto;">
                <!-- Logo -->
                <h2 class="text-center fw-bold mb-3">
                    <span class="text-dark">Shop</span>
                    <span style="color:#084298;">pable</span>
                </h2>

                <p class="text-center text-muted mb-4">
                    Create your account and start shopping today!
                </p>

                @if (TempData["not a customer"] != null)
                {
                    <div class="alert alert-warning text-center">
                        @TempData["not a customer"]
                    </div>
                }

                <form onsubmit="OnPhoneInput()" asp-action="SaveSignUp" method="post">

                    <div asp-validation-summary="All" class="text-danger mb-3"></div>

                    <!-- All your input fields... -->
                    <div class="mb-3">
                        <label asp-for="UserName" class="form-label fw-semibold"></label>
                        <input asp-for="UserName" class="form-control form-control-lg" placeholder="Enter your username" />
                        <span asp-validation-for="UserName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="FullName" class="form-label fw-semibold"></label>
                        <input asp-for="FullName" class="form-control form-control-lg" placeholder="Enter your full name" />
                        <span asp-validation-for="FullName" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Email" class="form-label fw-semibold"></label>
                        <input asp-for="Email" class="form-control form-control-lg" placeholder="Enter your email" />
                        <span asp-validation-for="Email" class="text-danger small"></span>
                    </div>

                    <!-- password -->
                    <div class="mb-3">
                        <label asp-for="Password" class="form-label fw-semibold"></label>
                        <input asp-for="Password" type="password" class="form-control form-control-lg" placeholder="Enter password" />
                        <span asp-validation-for="Password" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="ConfirmPassword" class="form-label fw-semibold"></label>
                        <input asp-for="ConfirmPassword" type="password" class="form-control form-control-lg" placeholder="Confirm password" />
                        <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
                    </div>


                    <!-- Address -->
                    <div class="mb-3">
                        <label asp-for="Address" class="form-label fw-semibold"></label>
                        <input asp-for="Address" class="form-control form-control-lg" placeholder="Enter your address" />
                        <span asp-validation-for="Address" class="text-danger small"></span>
                    </div>

                    <!-- Phone -->
                    <div class="mb-3 " >
                        <label asp-for="Phone" class="form-label fw-semibold"></label>
                        <span asp-validation-for="Phone" class="text-danger small"></span>
                        <div class="input-group">
                            <select id="countryCode" class="form-select" style="max-width:120px;">
                                <option value="+20">EG +20</option>
                                <option value="+966">SA +966</option>
                                <option value="+971">UAE +971</option>
                                <option value="+1">US +1</option>
                            </select>
                            <input id="phone" placeholder="Phone Number" class="form-control" />
                            <input type="hidden" id="fullphone" asp-for="Phone" />
                        </div>
                    </div>

                    @* <!-- City -->
                    <div id="customerFields"  >
                        <div class="mb-3">
                            <label class="form-label">City</label>
                            <input class="form-control"  />
                        </div>
                    </div> *@

                    @* <!-- Description -->
                    <div id="merchantFields" >
                        <div class="mb-3">
                            <label  class="form-label">Description</label>
                            <textarea  class="form-control" rows="3" placeholder="i am selling shoes,shirts, Tshirts, all clothes.."></textarea>
                        </div>
                    </div> *@

                    <!-- Role Selection -->
                    <div class="mb-4">

                        <label class="fw-semibold d-block mb-2">Sign Up as</label>
                        &emsp;
                        <div class="form-check form-check-inline">
                            <input id="Cust" type="radio" asp-for="Role" checked value="Customer" class="form-check-input role-toggle" />
                            <label for="Cust" class="form-check-label">Customer</label>
                        </div>
                        <br />&emsp;
                        <div class="form-check form-check-inline">
                            <input id="Merch" type="radio" asp-for="Role" value="Merchant" class="form-check-input role-toggle"  />
                            <label for="Merch" class="form-check-label">Merchant</label>
                        </div>
                    </div>
                    <button type="submit" class="btn btn-dark w-100 btn-lg rounded-3">
                        Register
                    </button>

                </form>

                <div class="text-center mt-4">
                    <span class="text-muted">Already have an account?</span>
                    <a class="text-decoration-none fw-semibold" asp-action="SignIn">Log In</a>
                </div>

            </div>
        </div>

    </div>
</div>

	 @section Scripts {
		<partial name="_ValidationScriptsPartial" />
		
		} 
    <script>
        function OnPhoneInput() {
            var code = document.getElementById("countryCode").value;
            var number = document.getElementById("phone").value;
            document.getElementById("fullphone").value = code + number;
        }
    document.querySelectorAll('.role-toggle').forEach(radio => {
        radio.addEventListener('change', function () {
            var customerDiv = document.getElementById('customerFields');
            var merchantDiv = document.getElementById('merchantFields');

            if (this.value === 'Merchant') {
                customerDiv.style.display = 'none';
                merchantDiv.style.display = 'block';
            } else {
                customerDiv.style.display = 'block';
                merchantDiv.style.display = 'none';
            }
        });
    });


    </script>
