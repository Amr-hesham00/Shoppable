@model Product


<!-- breadcrumb -->
<div class="container">
    <div class="bread-crumb flex-w p-l-25 p-r-15 p-t-30 p-lr-0-lg">
        <a asp-action="index" asp-controller="home" class="stext-109 cl8 hov-cl1 trans-04">
            Home
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <a asp-action="ShopProducts" asp-controller="product" class="stext-109 cl8 hov-cl1 trans-04">
            Shop
            <i class="fa fa-angle-right m-l-9 m-r-10" aria-hidden="true"></i>
        </a>

        <span class="stext-109 cl4">
            @Model.Name
        </span>
        <a 
           class="btn btn-outline-secondary"
           style="margin-left: auto;"
           onclick="history.back(); return false;">
            Back
        </a>
    </div>
</div>

<section class="sec-product-detail bg0 p-t-65 p-b-60">

    <div class="container">
        <div class="pd-section">
            <div class="pd-grid">

                <!-- Image Column -->
                <div>
                    <div class="pd-image-wrap">
                        @if (Model.ImageUrl?.Any() == true)
                        {
                            <img src="@Model.ImageUrl" alt="@Model.Name">
                            <a class="pd-img-expand" href="@Model.ImageUrl" target="_blank" title="Expand">
                                <svg width="14" height="14" viewBox="0 0 20 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                    <polyline points="15 3 21 3 21 9" />
                                    <polyline points="9 21 3 21 3 15" />
                                    <line x1="21" y1="3" x2="14" y2="10" />
                                    <line x1="3" y1="21" x2="10" y2="14" />
                                </svg>
                            </a>
                        }
                    </div>

                </div>

                <!-- Info Column -->
                <div class="pd-info">
                    <p class="pd-category ">In Stock</p>

                    <h4 class="pd-name js-name-detail">@Model.Name</h4>

                    <p class="pd-price">$@Model.Price</p>

                    <div class="pd-divider"></div>
                    <p class="pd-desc">@Model.Description</p>

                    <form asp-action="add" asp-controller="cart" method="post">

                        <input type="hidden" name="ProductId" value="@Model.Id" />

                        <!-- Size -->
                        <div class="pd-field">
                            <label asp-for="Sizes" class="pd-field-label">Size</label>
                            <div class="pd-custom-select" id="size-select">
                                <div class="selected" onclick="toggleSelect('size-select')">
                                    <span class="selected-text">Select a size</span>
                                    <span class="arrow"></span>
                                </div>
                                <div class="options">
                                    @foreach (var size in Model.Sizes)
                                    {
                                        <div class="option" onclick="pickOption('size-select', '@size')">@size</div>
                                    }
                                </div>
                                <select name="Size" asp-items="@(new SelectList(Model.Sizes))">
                                    <option value="">Select a size</option>
                                </select>
                            </div>
                            <span asp-validation-for="Sizes" class="pd-error"></span>
                        </div>

                        <!-- Color -->
                        <div class="pd-field">
                            <label asp-for="Colors" class="pd-field-label">Color</label>
                            <div class="pd-custom-select" id="color-select">
                                <div class="selected" onclick="toggleSelect('color-select')">
                                    <span class="selected-text">Select a color</span>
                                    <span class="arrow"></span>
                                </div>
                                <div class="options">
                                    @foreach (var color in Model.Colors)
                                    {
                                        <div class="option" onclick="pickOption('color-select', '@color')">@color</div>
                                    }
                                </div>
                                <select name="Color" asp-items="@(new SelectList(Model.Colors))">
                                    <option value="">Select a color</option>
                                </select>
                            </div>
                            <span asp-validation-for="Colors" class="pd-error"></span>
                        </div>

                        <!-- Quantity + Add to Cart -->
                        <div class="pd-qty-row">
                            <div class="pd-qty">
                                <button type="button" onclick="adjustQty(-1)">−</button>
                                <input type="number" id="qty-input" name="Quantity" value="1" min="1" max="100" readonly>
                                <button type="button" onclick="adjustQty(1)">+</button>
                            </div>
                            <button  type="submit" class="pd-btn-cart js-addcart-detail">Add to Cart</button>
                        </div>

                    </form>

                    <div class="pd-divider"></div>

                    <!-- Social Share -->
                    <div class="pd-social">
                        <span class="pd-social-label">visit us on </span>
                        <a href="https://www.instagram.com/" title="Instagram" target="_blank">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <rect x="2" y="2" width="20" height="20" rx="5" />
                                <circle cx="12" cy="12" r="4" />
                                <circle cx="17.5" cy="6.5" r="1" fill="currentColor" stroke="none" />
                            </svg>
                        </a>
                        <a href="https://www.facebook.com/" title="Facebook" target="_blank">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M18 2h-3a5 5 0 00-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 011-1h3z" />
                            </svg>
                        </a>
                        <a href="https://www.linkedin.com/feed/" title="LinkedIn" target="_blank">
                            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
                                <path d="M16 8a6 6 0 016 6v7h-4v-7a2 2 0 00-2-2 2 2 0 00-2 2v7h-4v-7a6 6 0 016-6z" />
                                <rect x="2" y="9" width="4" height="12" />
                                <circle cx="4" cy="4" r="2" />
                            </svg>
                        </a>
                    </div>

                </div>
            </div>
        </div>
    </div>


</section>







