<!--prod-details-->
<script>

    function adjustQty(delta) {
                const input = document.getElementById('qty-input');
                const val = parseInt(input.value) || 1;
                input.value = Math.max(1, Math.min(99, val + delta));
            }

                function toggleSelect(id) {
        const wrap = document.getElementById(id);
        const isOpen = wrap.querySelector('.options').classList.contains('open');
        document.querySelectorAll('.pd-custom-select .options.open').forEach(el => {
            el.classList.remove('open');
            el.previousElementSibling.classList.remove('open');
        });
        if (!isOpen) {
            wrap.querySelector('.options').classList.add('open');
            wrap.querySelector('.selected').classList.add('open');
        }
    }

    function pickOption(id, value) {
        const wrap = document.getElementById(id);
        wrap.querySelector('.selected-text').textContent = value;
        wrap.querySelector('select').value = value;
        wrap.querySelectorAll('.option').forEach(o => o.classList.remove('selected-opt'));
        wrap.querySelectorAll('.option').forEach(o => {
            if (o.textContent === value) o.classList.add('selected-opt');
        });
        wrap.querySelector('.options').classList.remove('open');
        wrap.querySelector('.selected').classList.remove('open');
    }

    document.addEventListener('click', function(e) {
        if (!e.target.closest('.pd-custom-select')) {
            document.querySelectorAll('.pd-custom-select .options.open').forEach(el => {
                el.classList.remove('open');
                el.previousElementSibling.classList.remove('open');
            });
        }
    });
</script>
<style>
    .pd-custom-select {
        position: relative;
        user-select: none;
    }

        .pd-custom-select .selected {
            padding: .75rem 1rem;
            border: 0.5px solid #ccc;
            border-radius: 2px;
            font-size: 13px;
            font-family: 'DM Sans', sans-serif;
            color: #1a1a1a;
            background: #fff;
            cursor: pointer;
            display: flex;
            justify-content: space-between;
            align-items: center;
            transition: border .2s;
        }

            .pd-custom-select .selected:hover {
                border-color: #1a1a1a;
            }

            .pd-custom-select .selected.open {
                border-color: #1a1a1a;
            }

        .pd-custom-select .arrow {
            width: 7px;
            height: 7px;
            border-right: 1px solid #888;
            border-bottom: 1px solid #888;
            transform: rotate(45deg);
            transition: transform .2s;
            margin-bottom: 3px;
        }

        .pd-custom-select .selected.open .arrow {
            transform: rotate(-135deg);
            margin-bottom: -3px;
        }

        .pd-custom-select .options {
            position: absolute;
            top: calc(100% + 4px);
            left: 0;
            right: 0;
            background: #fff;
            border: 0.5px solid #ccc;
            border-radius: 2px;
            z-index: 100;
            max-height: 0;
            overflow: hidden;
            transition: max-height .25s ease, opacity .2s ease;
            opacity: 0;
        }

            .pd-custom-select .options.open {
                max-height: 220px;
                opacity: 1;
            }

        .pd-custom-select .option {
            padding: .65rem 1rem;
            font-size: 13px;
            font-family: 'DM Sans', sans-serif;
            cursor: pointer;
            color: #555;
            transition: background .15s, color .15s;
            border-bottom: 0.5px solid #f0f0f0;
        }

            .pd-custom-select .option:last-child {
                border-bottom: none;
            }

            .pd-custom-select .option:hover {
                background: #f7f6f4;
                color: #1a1a1a;
            }

            .pd-custom-select .option.selected-opt {
                color: #1a1a1a;
                font-weight: 500;
            }
        /* hidden real select for form submission */
        .pd-custom-select select {
            display: none;
        }
    <!-- -->
    @@import url('https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;500;600&family=DM+Sans:wght@300;400;500&display=swap');

