@model Product

<div class="container mt-4">
    <div class="card shadow-lg border-0 rounded-4">

        <!-- Header -->
        <div class="card-header bg-info text-white rounded-top-4 d-flex justify-content-between align-items-center">
            <h4 class="mb-0">Product Details</h4>

            @if (Model.IsDeleted)
            {
                <span class="badge bg-danger">Inactive</span>
            }
            else
            {
                <span class="badge bg-success">Active</span>
            }
        </div>

        <div class="card-body p-4">

            <div class="row">

                <!-- Product Image -->
                <div class="col-md-4 text-center mb-3">
                    @if (Model.ImageUrl?.Any() == true)
                    {

                        <div class="slick3 gallery-lb">
                            <div class="item-slick3" data-thumb="@Model.ImageUrl">
                                <div class="wrap-pic-w pos-relative">
                                    <img src="@Model.ImageUrl" alt="IMG-PRODUCT">

                                    <a class="flex-c-m size-108 how-pos1 bor0 fs-16 cl10 bg0 hov-btn3 trans-04" target="_blank" href="@Model.ImageUrl">
                                        <i class="fa fa-expand"></i>
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Product Info -->
                <div class="col-md-8">

                    <h3 class="fw-bold">@Model.Name</h3>

                    <hr />

                    <h3>
                        <strong>Price:</strong>
                        <span class="text-success fs-30">@Model.Price.ToString("C")</span>
                    </h3>

                    <h3>
                        <strong>Description:</strong><br />
                        @Model.Description
                    </h3>

                    <h3>
                        <strong>Stock Quantity:</strong>
                        @if (Model.StockQuantity > 0)
                        {
                            <span class="badge bg-success">
                                @Model.StockQuantity in stock
                            </span>
                        }
                        else
                        {
                            <span class="badge bg-danger">
                                Out of Stock
                            </span>
                        }
                    </h3>

                    <h3>
                        <strong>Created At:</strong>
                        @Model.CreatedDate.ToString("yyyy-MM-dd")
                    </h3>

                    <h3>
                        <strong>Merchant ID:</strong>
                        @Model.MerchantId
                    </h3>

                </div>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between mt-4">

                <a asp-controller="Dashboard"
                   asp-action="Products"
                   class="btn btn-outline-secondary">
                    Back
                </a>

                <a asp-controller="Product"
                   asp-action="Edit"
                   asp-route-id="@Model.Id"
                   class="btn btn-warning">
                    Edit Product
                </a>

            </div>

        </div>
    </div>
</div>