@model Cart // i'll use this model here

@{
    var cartItems = Model?.cartitems?.ToList() ?? new List<CartItem>();
    var subtotal = cartItems.Sum(i => i.product.Price * i.Quantity);
    var hasItems = cartItems.Any();
}

<div class="cart-page bg0 p-t-75 p-b-85">
    <div class="container">
        @if (!hasItems)
        {
            <div class="cart-card empty-cart">
                <h3>Your cart is empty</h3>
                <p>
                    Looks like you have not added any products yet. Browse the shop and add your favorite items to start your order.
                </p>
                <a asp-controller="Product" asp-action="ShopProducts" class="continue-btn" style="max-width: 240px; margin: 0 auto;">
                    Continue Shopping
                </a>
            </div>
        }
        else
        {
            <form asp-action="update" asp-controller="cart" method="post">
                <div class="row">
                    <!-- left cart-->
                    <div class="col-lg-10 col-xl-7 m-lr-auto m-b-30">
                        <div class="cart-card">
                            <div class="cart-card-header">
                                <div>
                                    <h2 class="cart-card-title">Shopping Cart</h2>
                                    <p class="cart-card-subtitle">@cartItems.Count item@(cartItems.Count > 1 ? "s" : "") in your cart</p>
                                </div>

                                <a asp-action="Clear" asp-controller="Cart" class="clear-cart-btn">
                                    Clear All
                                </a>
                                <button type="submit" class="clear-cart-btn">
                                    Update
                                </button>
                                <input type="hidden" name="CartId" value="@Model.Id" />
                            </div>

                            <div class="cart-table-wrap">
                                <table class="cart-table">
                                    <thead>
                                        <tr>
                                            <th>Product</th>
                                            <th>Price</th>
                                            <th>Quantity</th>
                                            <th>Color</th>
                                            <th>Size</th>
                                            <th>Total</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for(int i = 0; i < cartItems.Count;i++)
                                        {
                                            <tr>
                                                <!--prod NAme-->
                                                <td>
                                                    <div class="cart-product">
                                                        <div class="cart-product-image">
                                                            <img src="@cartItems[i].product.ImageUrl" alt="@cartItems[i].product.Name" />
                                                        </div>

                                                        <div>
                                                            <div class="cart-product-name">@cartItems[i].product.Name </div>

                                                            @* <strong class="cart-product-meta">$ @cartItems[i].product.Price</strong> *@
                                                        </div>
                                                    </div>
                                                </td>

                                                <!--Price-->
                                                <td class="cart-price">$ @cartItems[i].product.Price.ToString("F2")</td>

                                                <!--Number-->
                                                <td>
                                                    <div class="qty-action-wrap">
                                                        <div class="wrap-num-product flex-w">
                                                            <div class="btn-num-product-down cl8 hov-btn3 trans-04 flex-c-m" onclick="adjustQty(this, -1)">
                                                                <i class="fs-16 zmdi zmdi-minus"></i>
                                                            </div>

                                                            <input class="mtext-104 cl3 txt-center num-product"
                                                                   type="number"
                                                                   asp-for="@cartItems[i].Quantity"
                                                                   min="1"
                                                                   max="50"
                                                                     />

                                                            <input type="hidden" asp-for="cartitems[i].Id" />

                                                            <div class="btn-num-product-up cl8 hov-btn3 trans-04 flex-c-m" onclick="adjustQty(this, 1)">
                                                                <i class="fs-16 zmdi zmdi-plus"></i>
                                                            </div>
                                                        </div>

                                                        <!--remove btn-->
                                                        <a asp-action="Remove"
                                                           asp-controller="Cart"
                                                           asp-route-itemId="@cartItems[i].Id"
                                                           class="remove-item-btn"
                                                           title="Remove item">
                                                            <i class="fs-20 zmdi zmdi-delete"></i>
                                                        </a>
                                                    </div>
                                                </td>

                                                <!--Color-->
                                                <td>
                                                    <span class="cart-variant">@cartItems[i].Color</span>
                                                </td>

                                                <!--size-->
                                                <td>
                                                    <span class="cart-variant">@cartItems[i].Size</span>
                                                </td>

                                                <!--total-->
                                                <td class="cart-total">$ @((cartItems[i].product.Price * cartItems[i].Quantity).ToString("F2"))</td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    </div>

                    <!-- right checkout -->
                    <div class="col-sm-10 col-lg-7 col-xl-5 m-lr-auto m-b-30">
                        <div class="cart-summary-card">
                            <h4 class="summary-title">Cart Summary</h4>

                            <div class="summary-row">
                                <span>Items</span>
                                <span>@cartItems.Sum(i => i.Quantity)</span>
                            </div>

                            <div class="summary-row">
                                <span>Subtotal</span>
                                <span>$ @subtotal.ToString("F2")</span>
                            </div>

                            <div class="summary-row">
                                <span>Shipping</span>
                                <span>Calculated at checkout</span>
                            </div>

                            <div class="summary-row total">
                                <span>Total</span>
                                <span>$ @subtotal.ToString("F2")</span>
                            </div>

                            <p class="summary-note">
                                Review your items before checkout.
                            </p>

                            <a asp-action="index" asp-controller="payment" asp-route-cartid="@Model.Id" asp-route-total="@subtotal" class="checkout-btn">
                                Proceed to Checkout
                            </a>

                            <a asp-controller="Product" asp-action="ShopProducts" class="continue-btn">
                                Continue Shopping
                            </a>

                        </div>
                    </div>
                </div>
            </form>
        }
    </div>
</div>

<script>
    function adjustQty(btn, delta) {
        const input = btn.closest('.wrap-num-product').querySelector('input');
        const val = parseInt(input.value) || 1;
        input.value = Math.max(1, Math.min(99, val + delta));
    }
</script>
