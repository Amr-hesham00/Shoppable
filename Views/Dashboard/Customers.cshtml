@model CustomersFilterVM

@{
    Layout = null;
    ViewData["Title"] = "Customers";
}
<!doctype html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <meta name="description" content="">
    <meta name="author" content="Mark Otto, Jacob Thornton, and Bootstrap contributors">
    <meta name="generator" content="Hugo 0.84.0">

    <link rel="canonical" href="https://getbootstrap.com/docs/5.0/examples/dashboard/">

    <!-- Bootstrap core CSS -->
    <link href="/bootstrap.min.css" rel="stylesheet">




    <!-- Custom styles for this template -->
    <link href="/css/dashboard.css" rel="stylesheet">
</head>
<body>

    <!-- header -->
    <header class="navbar navbar-dark sticky-top bg-dark shadow px-3">

        <!-- Left section -->
        <div class="d-flex align-items-center">

            <button class="navbar-toggler d-md-none me-2"
                    type="button"
                    data-bs-toggle="collapse"
                    data-bs-target="#sidebarMenu">
                <span class="navbar-toggler-icon"></span>
            </button>

            <a class="navbar-brand m-0 logo-gradient"
               asp-controller="Home"
               asp-action="Index">
                Shoppable
            </a>

        </div>

        <!-- Middle Section -->
        <div class="position-absolute start-50 translate-middle-x d-none d-md-block">
            <span class="dashboard-title">
                @ViewData["Title"] Management
            </span>
        </div>


        <!-- Right Section -->
        <div class="d-flex align-items-center ms-auto">

            <span class="text-white me-3 d-none d-lg-block">
                Welcome <strong>@User.Identity?.Name</strong>
            </span>

            <a class="btn btn-sm btn-outline-light"
               asp-action="SignOut"
               asp-controller="User">
                Sign out
            </a>

        </div>

    </header>

    <div class="container-fluid">
        <div class="row">

            <!-- side bar menu-->
            <nav id="sidebarMenu" class="col-md-3 col-lg-2 d-md-block bg-light sidebar collapse">
                <div class="position-sticky pt-3">
                    <ul class="nav flex-column">
                        <br />
                        <li class="nav-item">
                            <a class="nav-link " aria-current="page" asp-action="index">
                                <span data-feather="home"></span>
                                Dashboard
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link " aria-current="page" asp-action="account" asp-controller="dashboard">
                                <span data-feather="file"></span>
                                Account
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="orders" asp-controller="dashboard">
                                <span data-feather="file"></span>
                                Orders
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="Products" asp-controller="dashboard">
                                <span data-feather="shopping-cart"></span>
                                Products
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="Customers" asp-controller="dashboard">
                                <span data-feather="users"></span>
                                Customers
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="Analysis" asp-controller="dashboard">
                                <span data-feather="users"></span>
                                Analysis
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link" asp-action="Reports" asp-controller="dashboard">
                                <span data-feather="bar-chart-2"></span>
                                Reports
                            </a>
                        </li>

                    </ul>


                </div>
            </nav>

            <!-- main section-->
            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4">

                <!-- Header -->
                <div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3">
                    <button onclick="history.back()"
                            class="btn btn-sm btn-outline-dark ms-3 d-none d-md-inline">
                        ← Back
                    </button>

                    <h1 class="h2">Customers</h1>

                    <div class="btn-toolbar mb-2 mb-md-0">
                        <div class="btn-group me-2">
                            <button type="button" class="btn btn-sm btn-outline-secondary">Share</button>
                            <button type="button" class="btn btn-sm btn-outline-secondary">Export</button>
                        </div>
                    </div>
                </div>
                <!-------------------------- Filteration ----------------------------->
                <div class="card shadow-sm mb-4">
                    <div class="card-body">
                        <form asp-action="Customers" method="get">

                            <div class="row g-2 mb-3">
                                <div class="col-md-1">
                                    <label class="form-label fw-semibold small">ID</label>
                                    <input type="text" name="Id" class="form-control form-control-sm" placeholder="Id">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold small">Search</label>
                                    <input type="text" name="Name" value="@ViewData["CurrentFilter"]" class="form-control form-control-sm" placeholder="Name...">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold small">City</label>
                                    <input type="text" name="City" class="form-control form-control-sm">
                                </div>
                                <div class="col-md-2">
                                    <label class="form-label fw-semibold small">Phone</label>
                                    <input type="text" name="Phone" class="form-control form-control-sm">
                                </div>
                                
                            </div>

                            <div class="d-flex justify-content-start gap-2">
                                <a asp-action="Customers" class="btn btn-sm btn-outline-secondary px-4">Clear All Filters</a>
                                <button type="submit" class="btn btn-sm btn-primary px-5">Apply Filters</button>
                            </div>

                        </form>
                    </div>
                </div>
                <!------------------------------------------------------->
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="mb-3">Customers</h2>
                </div>

                <!--Customer Table-->
                @if (Model.customers != null && Model.customers.Count != 0)
                {
                    <div class="table-responsive">
                        <table class="table table-striped table-hover align-middle">
                            <thead class="table-dark">
                                <tr>
                                    <th>Customer Id</th>
                                    <th>Name</th>
                                    <th>Phone</th>
                                    <th>City</th>
                                    <td>Address</td>
                                    <th class="text-center">Actions</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var customer in Model.customers)
                                {
                                    <tr>
                                        <td>@customer.Id</td>
                                        <td>@customer.Name</td>
                                        <td>@customer.Phone</td>
                                        <td>@customer.City</td>
                                        <td>@customer.Address</td>

                                        <td class="text-center">
                                            <div class="btn-group btn-group-sm">

                                                <a asp-controller="Customer"
                                                   asp-action="Details"
                                                   asp-route-id="@customer.Id"
                                                   class="btn btn-outline-info">
                                                    Details
                                                </a>
                                                @* <a asp-controller="Customer"
                                                   asp-action="Orders"
                                                   asp-route-id="@customer.Id"
                                                   class="btn btn-outline-warning">
                                                    Orders
                                                </a> *@
                                                @* <a asp-controller="Customer"
                                                   asp-action="Delete"
                                                   asp-route-id="@customer.Id"
                                                   class="btn btn-outline-danger"
                                                   onclick="return confirm('Are you sure you want to Delete this order?');">
                                                    Delete
                                                </a> *@
                                            </div>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                        </table>
                    </div>
                }
                else
                {
                    <div class="text-center mt-4">
                        <h4>No customers found 😢</h4>
                        <p class="text-muted">
                            Customers will appear here when anyone Register.
                        </p>
                    </div>
                }

            </main>
        </div>
    </div>


    <script src="/bootstrap.bundle.min.js"></script>

    <script src="https://cdn.jsdelivr.net/npm/feather-icons@4.28.0/dist/feather.min.js" integrity="sha384-uO3SXW5IuS1ZpFPKugNNWqTZRRglnUJK6UAZ/gxOX80nxEkN9NcGZTftn6RzhGWE" crossorigin="anonymous"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js@2.9.4/dist/Chart.min.js" integrity="sha384-zNy6FEbO50N+Cg5wap8IKA4M/ZnLJgzc6w2NqACZaK0u0FXfOWRRJOnQtpZun8ha" crossorigin="anonymous"></script>
    <script src="/js/dashboard.js"></script>
    <style>
        .bd-placeholder-img {
            font-size: 1.125rem;
            text-anchor: middle;
            -webkit-user-select: none;
            -moz-user-select: none;
            user-select: none;
        }

        @@media (min-width: 768px) {
            .bd-placeholder-img-lg {
                font-size: 3.5rem;
            }
        }

        .logo-gradient {
            font-weight: 700;
            font-size: 28px;
            background: linear-gradient(45deg, #0d6efd, #6610f2);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }

        .dashboard-title {
            font-size: 1.35rem;
            font-weight: 680;
            letter-spacing: 1px;
            color: #ffffff;
            text-transform: uppercase;
        }
    </style>

</body>
</html>
