@model Order

@{
    ViewData["Title"] = "Order Details";
}

<h1>Order Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-3">Order ID</dt>
        <dd class="col-sm-9">@Model.Id</dd>

        <dt class="col-sm-3">Order Date</dt>
        <dd class="col-sm-9">@Model.OrderDate</dd>

        <dt class="col-sm-3">Total Amount</dt>
        <dd class="col-sm-9">@Model.TotalAmount</dd>

        <dt class="col-sm-3">Status</dt>
        <dd class="col-sm-9">@Model.Status</dd>

        <dt class="col-sm-3">Shipping Address</dt>
        <dd class="col-sm-9">@Model.ShippingAddress</dd>

        <dt class="col-sm-3">Customer ID</dt>
        <dd class="col-sm-9">@Model.CustomerId</dd>

        <dt class="col-sm-3">Customer</dt>
        <dd class="col-sm-9">
            @(Model.customer != null ? Model.customer.ToString() : "No customer data")
        </dd>

        <dt class="col-sm-3">Payment</dt>
        <dd class="col-sm-9">
            @(Model.payment != null ? Model.payment.ToString() : "No payment data")
        </dd>
    </dl>
</div>

@if (Model.orderItems != null && Model.orderItems.Any())
{
    <h3 class="mt-4">Order Items</h3>
    <table class="table table-bordered table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Item</th>
                <th>Quantity</th>
                <th>Price</th>
                <th>Subtotal</th>
            </tr>
        </thead>
        <tbody>
            @for (int i = 0; i < Model.orderItems.Count; i++)
            {
                var item = Model.orderItems[i];
                <tr>
                    <td>@(i + 1)</td>
                    <td>@item</td>
                    <td>@item.Quantity</td>
                    <td>@item.PriceAtPurchase.ToString("C")</td>
                    <td>@((item.Quantity * item.PriceAtPurchase).ToString("C"))</td>
                </tr>
            }
        </tbody>
    </table>
}
else
{
    <p class="mt-4 text-muted">No order items found.</p>
}

<div class="mt-4">
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Orders" asp-controller="dashboard" class="btn btn-secondary ms-2">Back to List</a>
</div>